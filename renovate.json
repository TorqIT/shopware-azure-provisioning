{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchManagers": ["github-actions", "dockerfile", "bicep"],
      "pinDigests": true,
      "groupName": "Weekly dependency updates",
      "schedule": ["on monday"]
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackagePrefixes": ["TorqIT/"],
      "pinDigests": false,
      "enabled": false
    }
  ]
}
