{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "groupName": "GitHub Actions",
      "schedule": ["on monday"]
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackagePrefixes": ["TorqIT/"],
      "pinDigests": false,
      "enabled": false
    },
    {
      "matchManagers": ["dockerfile"],
      "pinDigests": true,
      "groupName": "Docker",
      "schedule": ["on monday"]
    },
    {
      "matchManagers": ["bicep"],
      "groupName": "Bicep API versions",
      "schedule": ["on monday"]
    }
  ]
}
